fice/word/2020/wordml/sdtdatahash" xmlns:w16sdtfl="http://schemas.microsoft.com/office/word/2024/wordml/sdtformatlock" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh w16sdtfl w16du wp14"><w:body><w:p w14:paraId="001B8316" w14:textId="75168784" w:rsidR="00851E2B" w:rsidRPr="00851E2B" w:rsidRDefault="00851E2B" w:rsidP="00851E2B"><w:r w:rsidRPr="00851E2B"><w:t>Notes:</w:t></w:r><w:r w:rsidRPr="00851E2B"><w:br/><w:t>1. [LOW PRIORITY] For the output dashboard view, all boxes should be of matching height; please always format boxes to match tallest height</w:t></w:r><w:r w:rsidRPr="00851E2B"><w:br/></w:r><w:r w:rsidRPr="00851E2B"><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="3D578077" wp14:editId="4A032105"><wp:extent cx="5943600" cy="2019300"/><wp:effectExtent l="0" t="0" r="0" b="0"/><wp:docPr id="528844832" name="Picture 9"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="Picture 23"/><pic:cNvPicPr><a:picLocks noChangeAspect="1" noChangeArrowheads="1"/></pic:cNvPicPr></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId4"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr bwMode="auto"><a:xfrm><a:off x="0" y="0"/><a:ext cx="5943600" cy="2019300"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln><a:noFill/></a:ln></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="3A80883B" w14:textId="77777777" w:rsidR="00851E2B" w:rsidRPr="00851E2B" w:rsidRDefault="00851E2B" w:rsidP="00851E2B"><w:r w:rsidRPr="00851E2B"><w:t>2. [CRITICAL PRIORITY] In wiring diagram (harness routing view), AWG must be shown</w:t></w:r></w:p><w:p w14:paraId="6FF723D6" w14:textId="5F6F977F" w:rsidR="00851E2B" w:rsidRPr="00851E2B" w:rsidRDefault="00851E2B" w:rsidP="00851E2B"><w:r w:rsidRPr="00851E2B"><w:t>3. [HIGH PRIORITY] In wiring diagram (harness routing view), length dimension indicator should span full harness depiction width</w:t></w:r><w:r w:rsidRPr="00851E2B"><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="60E827BA" wp14:editId="3F1D3B0F"><wp:extent cx="5943600" cy="1714500"/><wp:effectExtent l="0" t="0" r="0" b="0"/><wp:docPr id="1493279579" name="Picture 8"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="Picture 24"/><pic:cNvPicPr><a:picLocks noChangeAspect="1" noChangeArrowheads="1"/></pic:cNvPicPr></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId5"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr bwMode="auto"><a:xfrm><a:off x="0" y="0"/><a:ext cx="5943600" cy="1714500"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln><a:noFill/></a:ln></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="7726C040" w14:textId="77777777" w:rsidR="00851E2B" w:rsidRPr="00851E2B" w:rsidRDefault="00851E2B" w:rsidP="00851E2B"><w:r w:rsidRPr="00851E2B"><w:t>4. [CRITICAL PRIORITY] In BOM, QTY for wiring should reflect length*(QTY indicated); the BOM should tell procurement how many feet of wire to buy total, and the unit will be a single foot</w:t></w:r></w:p><w:p w14:paraId="24AA4CAA" w14:textId="77777777" w:rsidR="00851E2B" w:rsidRPr="00851E2B" w:rsidRDefault="00851E2B" w:rsidP="00851E2B"><w:r w:rsidRPr="00851E2B"><w:t>5. [CRITICAL PRIORITY] In BOM, same QTY for shrink sleeve; QTY should be a function of length, where unit is 1 foot (i.e., a 12 ft cable should reflect QTY 12 in this field)</w:t></w:r></w:p><w:p w14:paraId="344BE183" w14:textId="0D28BC41" w:rsidR="00851E2B" w:rsidRPr="00851E2B" w:rsidRDefault="00851E2B" w:rsidP="00851E2B"><w:r w:rsidRPr="00851E2B"><w:t xml:space="preserve">6. [LOW PRIORITY] We lowkey hate the packaging notes, connection summary, and connection diagram; we would like to hide those for now, but if they serve some </w:t></w:r><w:r w:rsidRPr="00851E2B"><w:lastRenderedPageBreak/><w:t>functionality, we can keep the code</w:t></w:r><w:r w:rsidRPr="00851E2B"><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="4548E3E3" wp14:editId="52DD418E"><wp:extent cx="5943600" cy="3383280"/><wp:effectExtent l="0" t="0" r="0" b="7620"/><wp:docPr id="1935672690" name="Picture 7"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="Picture 25"/><pic:cNvPicPr><a:picLocks noChangeAspect="1" noChangeArrowheads="1"/></pic:cNvPicPr></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId6"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr bwMode="auto"><a:xfrm><a:off x="0" y="0"/><a:ext cx="5943600" cy="3383280"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln><a:noFill/></a:ln></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="5E172A91" w14:textId="52EDC9A8" w:rsidR="00851E2B" w:rsidRPr="00851E2B" w:rsidRDefault="00851E2B" w:rsidP="00851E2B"><w:r w:rsidRPr="00851E2B"><w:t xml:space="preserve">7. [CRITICAL PRIORITY] The wiring diagram (harness side view) is not formatted correctly: the signal names overlap the contact designators.  These </w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00851E2B"><w:t>shall</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="00851E2B"><w:t xml:space="preserve"> not overlap and must be legible.  We are also unclear on why pin B is alone by itself on the right side.  </w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00851E2B"><w:t>Takeaway, please</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="00851E2B"><w:t xml:space="preserve"> correct this formatting.</w:t></w:r><w:r w:rsidRPr="00851E2B"><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="185B42B9" wp14:editId="41180E6A"><wp:extent cx="5600700" cy="1722120"/><wp:effectExtent l="0" t="0" r="0" b="0"/><wp:docPr id="1548283564" name="Picture 6"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xm